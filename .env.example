# Local Docker Postgres
JOTHIDAM_DATABASE_URL=postgresql://slw_admin:slw_dev_password@localhost:5432/vinaadi_dev

# Auth - generate a strong random secret for production
JOTHIDAM_JWT_SECRET=replace-with-64-char-random-string

# Admin API key
JOTHIDAM_ADMIN_API_KEY=replace-with-strong-key

# MailHog (local dev) - swap for real SMTP in production
JOTHIDAM_SMTP_HOST=localhost
JOTHIDAM_SMTP_PORT=1025
JOTHIDAM_SMTP_USER=
JOTHIDAM_SMTP_PASS=
JOTHIDAM_NOTIFICATION_FROM_EMAIL=noreply@vinaadi.local
JOTHIDAM_NOTIFICATION_FROM_NAME=Vinaadi AI

# Birth data encryption (Fernet key)
JOTHIDAM_ENCRYPTION_KEY=replace-with-fernet-key
